# --- LiveKit (https://cloud.livekit.io -> project settings -> keys) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- LLM: Groq (https://console.groq.com/keys) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- STT: Deepgram (https://console.deepgram.com) ---
DEEPGRAM_API_KEY=

# --- TTS: ElevenLabs (https://elevenlabs.io -> profile -> API key) ---
ELEVENLABS_API_KEY=

# --- Warm transfer via Twilio + LiveKit SIP ---
# Create a LiveKit SIP outbound trunk wired to a Twilio Elastic SIP Trunk, then put its id here.
SIP_OUTBOUND_TRUNK_ID=
# The human agent's phone in E.164 format, e.g. +14155550123
HUMAN_AGENT_PHONE_NUMBER=

# --- SQLite (optional override) ---
# DB_PATH=appointments.db
